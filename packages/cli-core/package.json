{
  "name": "@hprabhash/shell-cli",
  "version": "0.1.0",
  "description": "Plugin-driven full-stack project generator — scaffold Next.js, Better Auth, Prisma/Drizzle, PostgreSQL, and shadcn/ui apps with one command.",
  "license": "MIT",
  "type": "module",
  "bin": {
    "shell": "./dist/bin.js"
  },
  "files": [
    "dist"
  ],
  "engines": {
    "node": ">=22.12.0"
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsup",
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "dev": "tsup --watch"
  },
  "dependencies": {
    "@clack/prompts": "^1.6.0",
    "@shell-cli/plugin-better-auth": "workspace:*",
    "@shell-cli/plugin-drizzle": "workspace:*",
    "@shell-cli/plugin-next": "workspace:*",
    "@shell-cli/plugin-postgres": "workspace:*",
    "@shell-cli/plugin-prisma": "workspace:*",
    "@shell-cli/shared": "workspace:*",
    "commander": "^15.0.0",
    "execa": "^9.6.1",
    "picocolors": "^1.1.1",
    "semver": "^7.8.5"
  },
  "devDependencies": {
    "@types/semver": "^7.7.1"
  }
}
