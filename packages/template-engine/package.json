{
  "name": "@hprabhash/template-engine",
  "version": "0.1.1",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsup",
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "dev": "tsup --watch"
  },
  "dependencies": {
    "@hprabhash/shared": "workspace:*",
    "handlebars": "^4.7.9"
  }
}
